{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /int/.codex/hooks/int_dispatcher.py || python D:\\int\\.codex\\hooks\\int_dispatcher.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /int/.codex/hooks/int_dispatcher.py || python D:\\int\\.codex\\hooks\\int_dispatcher.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /int/.codex/hooks/int_dispatcher.py || python D:\\int\\.codex\\hooks\\int_dispatcher.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
