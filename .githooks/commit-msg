#!/usr/bin/env bash
set -euo pipefail

message_file="${1:-}"

if [[ -z "$message_file" || ! -f "$message_file" ]]; then
  echo "Commit rejected: cannot read commit message." >&2
  exit 1
fi

if ! grep -Eiq '\bINT-[0-9]+\b' "$message_file"; then
  echo "Commit rejected: message must contain a Multica issue id in INT-* format." >&2
  exit 1
fi
