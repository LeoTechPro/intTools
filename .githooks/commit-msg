#!/usr/bin/env bash
set -euo pipefail

message_file="${1:-}"
checker="${INT_COMMIT_MESSAGE_CHECKER:-}"
if [[ -z "$checker" ]]; then
  workspace_root="$(git rev-parse --show-toplevel)"
  while [[ "$workspace_root" != "$(dirname "$workspace_root")" && ! -f "$workspace_root/scripts/commit-message-check.py" ]]; do
    workspace_root="$(dirname "$workspace_root")"
  done
  checker="$workspace_root/scripts/commit-message-check.py"
fi
if [[ ! -f "$checker" ]]; then
  echo "Commit отклонён: не найден workspace checker scripts/commit-message-check.py." >&2
  exit 1
fi
python_cmd="$(command -v python3 || command -v python || true)"
if [[ -z "$python_cmd" ]]; then
  echo "Commit отклонён: Python runtime не найден." >&2
  exit 1
fi
exec "$python_cmd" "$checker" "$message_file"
