#!/usr/bin/env bash
# Best-effort, NEVER-BLOCKING coordctl presence hook.
# Formula: tool = always-write + warn, agent = stop-on-real-overlap.
# This hook records provenance and prints advisory warnings; it always exits 0.
set -u

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$repo_root" ] || exit 0

coordctl_bin="$(command -v coordctl || true)"
if [ -z "$coordctl_bin" ] && [ -x "$repo_root/coordctl/coordctl" ]; then
  coordctl_bin="$repo_root/coordctl/coordctl"
fi
[ -n "$coordctl_bin" ] || exit 0

owner="${COORDCTL_OWNER:-${USER:-agent}:pre-commit}"

# Record presence (cheap, append-only, non-blocking).
"$coordctl_bin" begin --repo-root "$repo_root" --owner "$owner" --format json >/dev/null 2>&1 || true

# Advisory commit-scope report: surface warnings, never fail the commit.
report="$("$coordctl_bin" commit-scope-report --repo-root "$repo_root" --format json 2>/dev/null || true)"
if [ -n "$report" ]; then
  printf '%s' "$report" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for w in d.get("warnings", []) + d.get("observations", []):
    code = w.get("code", "")
    paths = ", ".join(w.get("paths", [])[:5])
    print(f"pre-commit[coordctl advisory]: {code} {paths}", file=sys.stderr)
' 2>/dev/null || true
fi

exit 0
