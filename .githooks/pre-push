#!/bin/bash
set -euo pipefail

# ENV POLICY GUARD
blocked_env_files=()
while IFS= read -r staged_file; do
  [[ -z "$staged_file" ]] && continue
  case "$staged_file" in
    *.env.example|*.local.example|*.example) continue ;;
  esac
  case "$staged_file" in
    .env|*.env|*/.env|*/.env.*|config/runtime/*.env|*/config/runtime/*.env)
      blocked_env_files+=("$staged_file")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if ((${#blocked_env_files[@]} > 0)); then
  echo "🚫 В индекс добавлены запрещённые env-файлы. Разрешены только *.env.example/*.example." >&2
  printf ' - %s\n' "${blocked_env_files[@]}" >&2
  exit 1
fi

mapfile -t push_lines
main_push_lines=()

for line in "${push_lines[@]}"; do
  [[ -z "$line" ]] && continue
  read -r local_ref local_sha remote_ref remote_sha <<<"$line"

  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    main_push_lines+=("$line")
  fi
done

if ((${#main_push_lines[@]} == 0)); then
  exit 0
fi

for line in "${main_push_lines[@]}"; do
  read -r local_ref local_sha remote_ref remote_sha <<<"$line"

  if [[ "${ALLOW_MAIN_PUSH:-}" != "1" ]]; then
    echo "Push в удалённый main требует подтверждения владельца. Запустите с ALLOW_MAIN_PUSH=1." >&2
    exit 1
  fi

  if [[ "$local_sha" =~ ^0+$ ]]; then
    echo "Удаление удалённой ветки main через push запрещено." >&2
    exit 1
  fi

  if [[ "$local_ref" != "refs/heads/main" ]]; then
    echo "Удалённая ветка main обновляется только из локальной main." >&2
    exit 1
  fi
done

# PUBLISH WRAPPER SMOKE GATE
if ! command -v pwsh >/dev/null 2>&1 && ! command -v powershell >/dev/null 2>&1; then
  echo "PowerShell executable is required to run codex.tests.test_publish_repo for pushes to main." >&2
  exit 1
fi

if command -v python >/dev/null 2>&1; then
  python -m unittest codex.tests.test_publish_repo -q
elif command -v python3 >/dev/null 2>&1; then
  python3 -m unittest codex.tests.test_publish_repo -q
else
  echo "Python interpreter is required to run codex.tests.test_publish_repo for pushes to main." >&2
  exit 1
fi

exit 0
