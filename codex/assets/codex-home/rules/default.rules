prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\n\nbase = Path('/git/tools/codex/assets/codex-home/skills')\nfor skill_dir in base.iterdir():\n    if not skill_dir.is_dir() or skill_dir.name.startswith('.') or skill_dir.name == 'dist':\n        continue\n    path = skill_dir / 'SKILL.md'\n    if not path.exists():\n        continue\n    text = path.read_text(encoding='utf-8')\n    text = re.sub(r'(?m)^##\\s+Execution\\s*$', '## Workflow', text)\n    text = re.sub(r'(?m)^##\\s+How to Use\\s*$', '## Workflow', text)\n    text = re.sub(r'(?m)^##\\s+Examples\\s*$', '## Examples', text)\n    path.write_text(text, encoding='utf-8')\n\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\npath = Path('/git/tools/codex/assets/codex-home/skills/supabase/SKILL.md')\ntext = path.read_text(encoding='utf-8')\ntext = text.replace('name: supabase-automation', 'name: supabase')\nold_desc = '\\\"Master Supabase CLI automation, auth configuration, edge functions, secrets management, MCP integration, and Management API for production deployments\\\"'\nnew_desc = 'Supabase CLI automation, auth configuration, Edge Functions, RPC/pgvector, secrets management, MCP integration, and Management API. Use for Supabase automation and ops.'\nif old_desc in text:\n    text = text.replace(old_desc, new_desc)\nelse:\n    text = text.replace('description: Master Supabase CLI automation, auth configuration, edge functions, secrets management, MCP integration, and Management API for production deployments', f'description: {new_desc}')\n\ninsert = \"## Additional References\\n\\n- `references/edge-functions.md` - Edge Functions invocation, deployment, and templates.\\n- `references/rpc-manager.md` - RPC execution, pgvector usage, and realtime patterns.\\n\\n\"\nmarker = \"## Documentation References\"\nif insert not in text:\n    text = text.replace(marker, insert + marker)\n\npath.write_text(text, encoding='utf-8')\nPY"], decision="allow")
