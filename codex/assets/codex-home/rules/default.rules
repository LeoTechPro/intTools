prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nimport os, re\nbase = '/git/tools/codex/assets/codex-home/skills'\nitems = sorted([d for d in os.listdir(base) if not d.startswith('.') and d not in {'dist'}])\nrows = []\nfor d in items:\n    path = os.path.join(base, d, 'SKILL.md')\n    if not os.path.exists(path):\n        rows.append((d, None))\n        continue\n    with open(path, 'r', encoding='utf-8') as f:\n        content = f.read()\n    m = re.match(r'^---\\n(.*?)\\n---\\n', content, re.S)\n    desc = None\n    if m:\n        y = m.group(1)\n        for line in y.splitlines():\n            if line.startswith('description:'):\n                desc = line.split(':',1)[1].strip()\n                break\n    rows.append((d, desc))\nfor name, desc in rows:\n    print(f\"{name}\\t{desc or ''}\")\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\n\nskills = {\n    'artifacts-builder': \"Набор инструментов для создания сложных HTML-артефактов Codex (React, Tailwind, shadcn/ui) с состоянием и роутингом. Использовать для многостраничных/многокомпонентных интерфейсов, не для простых одиночных HTML/JSX.\",\n    'create-plan': \"Создание краткого плана. Использовать, когда пользователь явно просит план действий по задаче.\",\n    'frontend-design': \"Дизайн и реализация выразительных фронтенд-интерфейсов высокого качества. Использовать при запросах на верстку/дизайн страниц, компонентов или приложений.\",\n    'javascript': \"Стандарты JavaScript/ES6+ (Airbnb), современные паттерны и Jest-тестирование. Использовать для проектов JS/TS, требующих чистого и поддерживаемого кода.\",\n    'nextjs-development': \"Разработка на Next.js 14+ (App Router, RSC, Server Actions, SSR, API, Tailwind, shadcn/ui, auth, perf, SEO). Использовать для задач на Next.js.\",\n    'pdf': \"Работа с PDF: извлечение текста/таблиц, создание, объединение/разделение, формы. Использовать для любых задач по PDF.\",\n    'playwright': \"Автоматизация браузера с Playwright: тесты страниц, формы, скриншоты, проверка UX/адаптива, логины, ссылки. Использовать для веб-тестирования и автоматизации.\",\n    'playwright-testing': \"Планирование, генерация и починка Playwright-тестов. Использовать для тест-планов, написания тестов по сценариям и отладки флейков.\",\n    'postgres': \"PostgreSQL: проектирование схем, миграции, оптимизация запросов и индексов, производительность и эксплуатация. Использовать для задач по Postgres.\",\n    'postgres-syntax': \"Справочник синтаксиса PostgreSQL (gram.y/DDL). Использовать, когда нужно разобраться в синтаксисе SQL Postgres.\",\n    'react': \"React 19: паттерны и стандарты фронтенда (hooks, Suspense, типизация, тесты, a11y, perf). Использовать для задач по React.\",\n    'react-component-generator': \"Генерация React-компонентов на TypeScript с корректной типизацией props и хуками. Использовать при запросе «создай компонент».\",\n    'review-punctb': \"Проектный код-ревью PunctB с записью отчета в reviews/ и чек-листами для React, Supabase Edge и Postgres. Использовать при ревью/аудите изменений.\",\n    'shadcn-ui': \"Внедрение и использование компонентов shadcn/ui (Radix + Tailwind). Использовать при работе с этим UI-набором.\",\n    'supabase': \"Supabase: CLI-автоматизация, конфигурация auth, Edge Functions, RPC/pgvector, секреты, MCP и Management API. Использовать для задач по Supabase и ops.\",\n    'supabase-auth-expert': \"Supabase Auth: регистрация/вход, управление пользователями, admin-операции и восстановление. Использовать для задач аутентификации.\",\n    'supabase-rls-policy-generator': \"Генерация RLS-политик Supabase для многотенантности и ролей. Использовать при запросах на RLS/политики доступа.\",\n}\n\nbase = Path('/git/tools/codex/assets/codex-home/skills')\n\nfor name, desc in skills.items():\n    path = base / name / 'SKILL.md'\n    if not path.exists():\n        raise SystemExit(f'missing {path}')\n    text = path.read_text(encoding='utf-8')\n    def repl(match):\n        return f\"description: {desc}\"\n    new_text, n = re.subn(r'^description:.*$', repl, text, flags=re.M)\n    if n == 0:\n        raise SystemExit(f'description not found in {path}')\n    path.write_text(new_text, encoding='utf-8')\n\nPY"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "python3 - <<'PY'\nfrom pathlib import Path\nimport re\n\nbase = Path('/git/tools/codex/assets/codex-home/skills')\nfor skill_dir in base.iterdir():\n    if not skill_dir.is_dir() or skill_dir.name.startswith('.') or skill_dir.name == 'dist':\n        continue\n    path = skill_dir / 'SKILL.md'\n    if not path.exists():\n        continue\n    text = path.read_text(encoding='utf-8')\n    if not text.startswith('---'):\n        continue\n    parts = text.split('---', 2)\n    if len(parts) < 3:\n        continue\n    front = parts[1]\n    body = parts[2]\n    lines = front.splitlines()\n    changed = False\n    for i, line in enumerate(lines):\n        if line.startswith('description:'):\n            value = line.split(':', 1)[1].strip()\n            if (value.startswith('\"') and value.endswith('\"')) or (value.startswith(\"'\") and value.endswith(\"'\")):\n                value = value[1:-1]\n            value = value.replace('\"', '\\\\\"')\n            lines[i] = f'description: \"{value}\"'\n            changed = True\n            break\n    if changed:\n        new_front = '\\n'.join(lines)\n        new_text = f\"---\\n{new_front}\\n---{body}\"\n        path.write_text(new_text, encoding='utf-8')\nPY"], decision="allow")
prefix_rule(pattern=["node", ".agents/scripts/web_preview_sanity.mjs"], decision="allow")
