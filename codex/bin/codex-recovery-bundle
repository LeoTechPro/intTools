#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
CODEX_RUNTIME_ROOT="${CODEX_RUNTIME_ROOT:-/git/.runtime}"
CODEX_SECRETS_ROOT="${CODEX_SECRETS_ROOT:-$CODEX_RUNTIME_ROOT/codex-secrets}"
CLOUD_ACCESS_ROOT="${CLOUD_ACCESS_ROOT:-$CODEX_RUNTIME_ROOT/cloud-access}"
OPENCLAW_SECRETS_ROOT="${OPENCLAW_SECRETS_ROOT:-$HOME/.openclaw/secrets}"
PASS_ENV_VAR="CODEX_RECOVERY_PASSPHRASE"

usage() {
  cat <<'EOF'
Usage:
  codex-recovery-bundle export /path/to/codex-recovery.tgz.enc
  codex-recovery-bundle import /path/to/codex-recovery.tgz.enc

Environment:
  CODEX_RECOVERY_PASSPHRASE  Optional non-interactive passphrase.
EOF
}

ensure_passphrase() {
  if [[ -n "${!PASS_ENV_VAR:-}" ]]; then
    return 0
  fi
  read -rsp "Recovery bundle passphrase: " passphrase
  echo
  export "${PASS_ENV_VAR}=$passphrase"
}

cmd="${1:-}"
bundle_path="${2:-}"

[[ -n "$cmd" && -n "$bundle_path" ]] || { usage >&2; exit 1; }

ensure_passphrase

case "$cmd" in
  export)
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    mkdir -p "$tmp_dir/git/.runtime" "$tmp_dir/home/.openclaw"
    rsync -a "$CODEX_SECRETS_ROOT/" "$tmp_dir/git/.runtime/codex-secrets/"
    if [[ -f "$CLOUD_ACCESS_ROOT/rclone.conf" ]]; then
      mkdir -p "$tmp_dir/git/.runtime/cloud-access"
      rsync -a "$CLOUD_ACCESS_ROOT/rclone.conf" "$tmp_dir/git/.runtime/cloud-access/"
    fi
    rsync -a "$OPENCLAW_SECRETS_ROOT/" "$tmp_dir/home/.openclaw/secrets/"
    python3 - <<'PY' "$tmp_dir/manifest.json"
from datetime import datetime, timezone
from pathlib import Path
import json
import sys

manifest_path = Path(sys.argv[1])
payload = {
    "created_at_utc": datetime.now(timezone.utc).isoformat(),
    "paths": [
        "/git/.runtime/codex-secrets/",
        "/git/.runtime/cloud-access/rclone.conf",
        "~/.openclaw/secrets/",
    ],
}
manifest_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
PY
    tar -C "$tmp_dir" -czf - . \
      | openssl enc -aes-256-cbc -pbkdf2 -salt -pass "env:${PASS_ENV_VAR}" -out "$bundle_path"
    echo "exported recovery bundle to $bundle_path"
    ;;
  import)
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    openssl enc -d -aes-256-cbc -pbkdf2 -pass "env:${PASS_ENV_VAR}" -in "$bundle_path" \
      | tar -C "$tmp_dir" -xzf -
    mkdir -p "$CODEX_SECRETS_ROOT" "$OPENCLAW_SECRETS_ROOT"
    if [[ -d "$tmp_dir/git/.runtime/codex-secrets" ]]; then
      rsync -a "$tmp_dir/git/.runtime/codex-secrets/" "$CODEX_SECRETS_ROOT/"
    fi
    if [[ -f "$tmp_dir/git/.runtime/cloud-access/rclone.conf" ]]; then
      mkdir -p "$CLOUD_ACCESS_ROOT"
      rsync -a "$tmp_dir/git/.runtime/cloud-access/rclone.conf" "$CLOUD_ACCESS_ROOT/"
    fi
    if [[ -d "$tmp_dir/home/.openclaw/secrets" ]]; then
      rsync -a "$tmp_dir/home/.openclaw/secrets/" "$OPENCLAW_SECRETS_ROOT/"
    fi
    echo "imported recovery bundle from $bundle_path"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
