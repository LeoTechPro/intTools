#!/usr/bin/env bash
set -euo pipefail
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
OPEN_SPEC_BIN="$ROOT_DIR/tools/openspec/node_modules/.bin/openspec"
if [[ ! -x "$OPEN_SPEC_BIN" ]]; then
  echo "openspec не установлен локально. Запустите: $ROOT_DIR/tools/install_tools.sh" >&2
  exit 2
fi
exec "$OPEN_SPEC_BIN" "$@"
