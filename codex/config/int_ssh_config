# Repo-managed SSH config for /int tailnet-first transport.
# Use with: ssh -F /int/tools/codex/config/int_ssh_config <host-alias>

Host int-dev-intdata-public
    HostName vds.intdata.pro
    User intdata
    IdentityFile ~/.ssh/id_ed25519_vds_intdata_intdata
    IdentitiesOnly yes
    BatchMode yes
    ConnectTimeout 5
    StrictHostKeyChecking accept-new

