{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /int/tools/codex/hooks/codex_hooks_dispatcher.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /int/tools/codex/hooks/codex_hooks_dispatcher.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
