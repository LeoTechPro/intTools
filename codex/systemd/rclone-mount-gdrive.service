[Unit]
Description=Rclone mount for Google Drive
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=RCLONE_CONFIG=/git/.runtime/cloud-access/rclone.conf
ExecStartPre=/git/scripts/codex/cloud_access.sh ensure-dirs
ExecStart=/git/scripts/codex/cloud_access.sh mount gdrive /git/cloud/gdrive
ExecStop=/git/scripts/codex/cloud_access.sh umount /git/cloud/gdrive
Restart=on-failure
RestartPreventExitStatus=3
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=default.target
