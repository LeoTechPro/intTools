[Unit]
Description=Rclone mount for Yandex Disk
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=RCLONE_CONFIG=/int/tools/.runtime/cloud-access/rclone.conf
ExecStartPre=/int/tools/codex/cloud_access.sh ensure-dirs
ExecStart=/int/tools/codex/cloud_access.sh mount yadisk /int/cloud/yadisk
ExecStop=/int/tools/codex/cloud_access.sh umount /int/cloud/yadisk
Restart=on-failure
RestartPreventExitStatus=3
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=default.target
