model = "gpt-5.4"
sandbox_mode = "danger-full-access"
dangerously_bypass_approvals_and_sandbox = true
model_reasoning_effort = "high"
default_cwd = "__INT_ROOT__"
personality = "pragmatic"
web_search = "live"
suppress_unstable_features_warning = true
[features]
unified_exec = true
shell_snapshot = __SHELL_SNAPSHOT__
multi_agent = true
steer = true


[projects."__HOME_ROOT__"]
trust_level = "trusted"

[projects."__INT_ROOT__/data"]
trust_level = "trusted"

[projects."__INT_ROOT__"]
trust_level = "trusted"

[projects."__INT_ROOT__/leonid"]
trust_level = "trusted"

[projects."__INT_ROOT__/assess"]
trust_level = "trusted"

[projects."__HOME_ROOT__"]
trust_level = "trusted"

[profiles.safe]
model = "gpt-5-codex"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
unified_exec = true
shell_snapshot = __SHELL_SNAPSHOT__

web_search = "live"
[notice]
suppress_unstable_features_warning = true
hide_gpt5_1_migration_prompt = true
hide_full_access_warning = true
hide_rate_limit_model_nudge = true

[notice.model_migrations]
"gpt-5.2-codex" = "gpt-5.2-codex"
"gpt-5.1-codex-mini" = "gpt-5.2-codex"

[mcp_servers.github]
command = "__MCP_GITHUB_COMMAND__"
__MCP_GITHUB_ARGS__

[mcp_servers.filesystem]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "__INT_ROOT__", "__BRAIN_ROOT__", "__CODEX_HOME__"]

[mcp_servers.gdrive_fs]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "__CLOUD_ROOT__/gdrive"]

[mcp_servers.yadisk_fs]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "__CLOUD_ROOT__/yadisk"]

[mcp_servers.postgres]
command = "__MCP_POSTGRES_COMMAND__"
__MCP_POSTGRES_ARGS__

[mcp_servers.playwright]
command = "npx"
args = ["@playwright/mcp@latest"]

[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"

[mcp_servers.obsidian_memory]
command = "__MCP_OBSIDIAN_COMMAND__"
__MCP_OBSIDIAN_ARGS__

[mcp_servers.bitrix24]
command = "__MCP_BITRIX24_COMMAND__"
__MCP_BITRIX24_ARGS__

[mcp_servers.intbrain]
command = "__INT_ROOT__/tools/codex/bin/mcp-intdata-cli.cmd"
args = ["--profile", "intbrain"]

[mcp_servers.intdata-control]
command = "__INT_ROOT__/tools/codex/bin/mcp-intdata-cli.cmd"
args = ["--profile", "intdata-control"]

[mcp_servers.intdata-runtime]
command = "__INT_ROOT__/tools/codex/bin/mcp-intdata-cli.cmd"
args = ["--profile", "intdata-runtime"]

[mcp_servers.dba]
command = "__INT_ROOT__/tools/codex/bin/mcp-intdata-cli.cmd"
args = ["--profile", "dba"]
