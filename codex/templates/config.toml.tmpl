model = "gpt-5.4"
sandbox_mode = "danger-full-access"
dangerously_bypass_approvals_and_sandbox = true
model_reasoning_effort = "high"
default_cwd = "/int"
personality = "pragmatic"
web_search = "live"
suppress_unstable_features_warning = true
[features]
unified_exec = true
shell_snapshot = true
multi_agent = false
steer = true


[projects."/home/leon/"]
trust_level = "trusted"

[projects."/int/data"]
trust_level = "trusted"

[projects."/int"]
trust_level = "trusted"

[projects."/int/leonid"]
trust_level = "trusted"

[projects."/int/assess"]
trust_level = "trusted"

[projects."/home/leon"]
trust_level = "trusted"

[profiles.safe]
model = "gpt-5-codex"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
unified_exec = true
shell_snapshot = true

web_search = "live"
[notice]
suppress_unstable_features_warning = true
hide_gpt5_1_migration_prompt = true
hide_full_access_warning = true
hide_rate_limit_model_nudge = true

[notice.model_migrations]
"gpt-5.2-codex" = "gpt-5.2-codex"
"gpt-5.1-codex-mini" = "gpt-5.2-codex"

[mcp_servers.github]
command = "/int/tools/codex/bin/mcp-github-from-gh.sh"

[mcp_servers.filesystem]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "/int", "/2brain", "__CODEX_HOME__"]

[mcp_servers.gdrive_fs]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "/int/cloud/gdrive"]

[mcp_servers.yadisk_fs]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "/int/cloud/yadisk"]

[mcp_servers.postgres]
command = "/int/tools/codex/bin/mcp-postgres-from-backend-env.sh"

[mcp_servers.playwright]
command = "npx"
args = ["@playwright/mcp@latest"]

[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"

[mcp_servers.obsidian_memory]
command = "/int/tools/codex/bin/mcp-obsidian-memory.sh"

[mcp_servers.timeweb]
command = "/int/tools/codex/bin/mcp-timeweb.sh"

[mcp_servers.timeweb_readonly]
command = "/int/tools/codex/bin/mcp-timeweb-readonly.sh"

[mcp_servers.bitrix24]
command = "/int/tools/codex/bin/mcp-bitrix24.sh"

[mcp_servers.lockctl]
command = "lockctl-mcp.cmd"
