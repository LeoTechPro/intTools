# Required amoCRM access
AMO_SUBDOMAIN=your-subdomain
AMO_ACCESS_TOKEN=your-access-token

# Required for amoCRM token auto-refresh
AMO_CLIENT_ID=your-client-id
AMO_CLIENT_SECRET=your-client-secret
AMO_REFRESH_TOKEN=your-refresh-token

# Optional server settings
AMO_TRANSPORT=stdio
AMO_PORT=8000

# Optional omnichannel communication through Umnico v1.3
UMNICO_API_KEY=your-umnico-account-jwt
UMNICO_BASE_URL=https://api.umnico.com/v1.3
