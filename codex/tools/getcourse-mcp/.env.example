# Required
GETCOURSE_ACCOUNT_DOMAIN=your-account.getcourse.ru
GETCOURSE_API_KEY=your-getcourse-api-key

# Optional aliases supported for older punctb configs
# GETCOURSE_LMS_PUNCTB_PRO_API_KEY=your-getcourse-api-key
# GETCOURSE_LMS_PUNKTB_PRO_API_KEY=your-getcourse-api-key

# Optional
GETCOURSE_TRANSPORT=stdio
GETCOURSE_PORT=8011
GETCOURSE_TIMEOUT=30
