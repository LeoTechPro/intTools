# Локальные runtime-профили intDBA
# Скопируйте этот файл в .env и заполните реальные значения локально.
# Файл .env должен оставаться untracked.

# Для migrate data --mode incremental требуется bash.
# На Windows рекомендуется Git for Windows с bash.exe в PATH.

# Правило именования профилей:
# DBA_PROFILE__<PROFILE_NAME>__<FIELD>=...
# Пример: профиль INTDATA_DEV в CLI вызывается как intdata-dev

# ------------------------------------------------------------
# Legacy profiles (example)
# ------------------------------------------------------------
DBA_PROFILE__INTDATA_DEV__PGHOST=api.intdata.pro
DBA_PROFILE__INTDATA_DEV__PGPORT=5432
DBA_PROFILE__INTDATA_DEV__PGDATABASE=intdatadb-dev
DBA_PROFILE__INTDATA_DEV__PGUSER=intdata_dev
DBA_PROFILE__INTDATA_DEV__PGPASSWORD=<fill-locally>
DBA_PROFILE__INTDATA_DEV__PGSSLMODE=require
DBA_PROFILE__INTDATA_DEV__WRITE_CLASS=nonprod

DBA_PROFILE__INTDATA_PROD__PGHOST=vds.intdata.pro
DBA_PROFILE__INTDATA_PROD__PGPORT=5432
DBA_PROFILE__INTDATA_PROD__PGDATABASE=intdata
DBA_PROFILE__INTDATA_PROD__PGUSER=intdata_prod
DBA_PROFILE__INTDATA_PROD__PGPASSWORD=<fill-locally>
DBA_PROFILE__INTDATA_PROD__PGSSLMODE=require
DBA_PROFILE__INTDATA_PROD__WRITE_CLASS=prod

# ------------------------------------------------------------
# Punkt-B hardened entrypoint profiles (custom roles only)
# ------------------------------------------------------------
# PROD readonly (new prod)
DBA_PROFILE__PUNKTB_PROD_RO__PGHOST=vds.punkt-b.pro
DBA_PROFILE__PUNKTB_PROD_RO__PGPORT=5432
DBA_PROFILE__PUNKTB_PROD_RO__PGDATABASE=punkt_b_prod
DBA_PROFILE__PUNKTB_PROD_RO__PGUSER=db_readonly_prod
DBA_PROFILE__PUNKTB_PROD_RO__PGPASSWORD=<fill-locally>
DBA_PROFILE__PUNKTB_PROD_RO__PGSSLMODE=prefer
DBA_PROFILE__PUNKTB_PROD_RO__WRITE_CLASS=prod

# PROD readonly (legacy)
DBA_PROFILE__PUNKTB_LEGACY_RO__PGHOST=vds.punkt-b.pro
DBA_PROFILE__PUNKTB_LEGACY_RO__PGPORT=5432
DBA_PROFILE__PUNKTB_LEGACY_RO__PGDATABASE=punkt_b_legacy_prod
DBA_PROFILE__PUNKTB_LEGACY_RO__PGUSER=db_readonly_prod
DBA_PROFILE__PUNKTB_LEGACY_RO__PGPASSWORD=<fill-locally>
DBA_PROFILE__PUNKTB_LEGACY_RO__PGSSLMODE=prefer
DBA_PROFILE__PUNKTB_LEGACY_RO__WRITE_CLASS=prod

# PROD migrator (controlled pipeline only)
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGHOST=vds.punkt-b.pro
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGPORT=5432
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGDATABASE=punkt_b_prod
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGUSER=db_migrator_prod
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGPASSWORD=<fill-locally>
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__PGSSLMODE=prefer
DBA_PROFILE__PUNKTB_PROD_MIGRATOR__WRITE_CLASS=prod

# PROD admin (breakglass only)
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGHOST=vds.punkt-b.pro
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGPORT=5432
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGDATABASE=punkt_b_prod
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGUSER=agents
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGPASSWORD=<fill-locally>
DBA_PROFILE__PUNKTB_PROD_ADMIN__PGSSLMODE=prefer
DBA_PROFILE__PUNKTB_PROD_ADMIN__WRITE_CLASS=prod

# DEV readonly
DBA_PROFILE__INTDATA_DEV_RO__PGHOST=vds.intdata.pro
DBA_PROFILE__INTDATA_DEV_RO__PGPORT=5432
DBA_PROFILE__INTDATA_DEV_RO__PGDATABASE=intdata
DBA_PROFILE__INTDATA_DEV_RO__PGUSER=db_readonly_dev
DBA_PROFILE__INTDATA_DEV_RO__PGPASSWORD=<fill-locally>
DBA_PROFILE__INTDATA_DEV_RO__PGSSLMODE=prefer
DBA_PROFILE__INTDATA_DEV_RO__WRITE_CLASS=nonprod

# DEV migrator
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGHOST=vds.intdata.pro
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGPORT=5432
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGDATABASE=intdata
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGUSER=db_migrator_dev
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGPASSWORD=<fill-locally>
DBA_PROFILE__INTDATA_DEV_MIGRATOR__PGSSLMODE=prefer
DBA_PROFILE__INTDATA_DEV_MIGRATOR__WRITE_CLASS=nonprod

# DEV admin (breakglass only)
DBA_PROFILE__INTDATA_DEV_ADMIN__PGHOST=vds.intdata.pro
DBA_PROFILE__INTDATA_DEV_ADMIN__PGPORT=5432
DBA_PROFILE__INTDATA_DEV_ADMIN__PGDATABASE=intdata
DBA_PROFILE__INTDATA_DEV_ADMIN__PGUSER=agents
DBA_PROFILE__INTDATA_DEV_ADMIN__PGPASSWORD=<fill-locally>
DBA_PROFILE__INTDATA_DEV_ADMIN__PGSSLMODE=prefer
DBA_PROFILE__INTDATA_DEV_ADMIN__WRITE_CLASS=nonprod

# Remote disposable test DB contour for /int/data is retired.
# For clean smoke/bootstrap use `dba local-test run` on the owner PC instead.
