# Локальные runtime-профили intdb
# Скопируйте этот файл в .env и заполните реальные значения локально.
# Файл .env должен оставаться untracked.

# Для migrate data --mode incremental требуется bash.
# На Windows рекомендуется Git for Windows с bash.exe в PATH.

# Правило именования профилей:
# INTDB_PROFILE__<PROFILE_NAME>__<FIELD>=...
# Пример: профиль INTDATA_DEV в CLI вызывается как intdata-dev

# ------------------------------------------------------------
# Legacy profiles (example)
# ------------------------------------------------------------
INTDB_PROFILE__INTDATA_DEV__PGHOST=api.intdata.pro
INTDB_PROFILE__INTDATA_DEV__PGPORT=5432
INTDB_PROFILE__INTDATA_DEV__PGDATABASE=intdatadb-dev
INTDB_PROFILE__INTDATA_DEV__PGUSER=intdata_dev
INTDB_PROFILE__INTDATA_DEV__PGPASSWORD=<fill-locally>
INTDB_PROFILE__INTDATA_DEV__PGSSLMODE=require
INTDB_PROFILE__INTDATA_DEV__WRITE_CLASS=nonprod

INTDB_PROFILE__INTDATA_PROD__PGHOST=vds.intdata.pro
INTDB_PROFILE__INTDATA_PROD__PGPORT=5432
INTDB_PROFILE__INTDATA_PROD__PGDATABASE=intdata
INTDB_PROFILE__INTDATA_PROD__PGUSER=intdata_prod
INTDB_PROFILE__INTDATA_PROD__PGPASSWORD=<fill-locally>
INTDB_PROFILE__INTDATA_PROD__PGSSLMODE=require
INTDB_PROFILE__INTDATA_PROD__WRITE_CLASS=prod

# ------------------------------------------------------------
# Punkt-B hardened entrypoint profiles (custom roles only)
# ------------------------------------------------------------
# PROD readonly (new prod)
INTDB_PROFILE__PUNKTB_PROD_RO__PGHOST=192.168.0.8
INTDB_PROFILE__PUNKTB_PROD_RO__PGPORT=5432
INTDB_PROFILE__PUNKTB_PROD_RO__PGDATABASE=punkt_b_prod
INTDB_PROFILE__PUNKTB_PROD_RO__PGUSER=db_readonly_prod
INTDB_PROFILE__PUNKTB_PROD_RO__PGPASSWORD=<fill-locally>
INTDB_PROFILE__PUNKTB_PROD_RO__PGSSLMODE=prefer
INTDB_PROFILE__PUNKTB_PROD_RO__WRITE_CLASS=prod

# PROD readonly (legacy)
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGHOST=192.168.0.8
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGPORT=5432
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGDATABASE=punkt_b_legacy_prod
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGUSER=db_readonly_legacy
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGPASSWORD=<fill-locally>
INTDB_PROFILE__PUNKTB_LEGACY_RO__PGSSLMODE=prefer
INTDB_PROFILE__PUNKTB_LEGACY_RO__WRITE_CLASS=prod

# PROD migrator (controlled pipeline only)
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGHOST=192.168.0.8
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGPORT=5432
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGDATABASE=punkt_b_prod
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGUSER=db_migrator_prod
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGPASSWORD=<fill-locally>
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__PGSSLMODE=prefer
INTDB_PROFILE__PUNKTB_PROD_MIGRATOR__WRITE_CLASS=prod

# PROD admin (breakglass only)
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGHOST=192.168.0.8
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGPORT=5432
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGDATABASE=punkt_b_prod
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGUSER=db_admin_prod
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGPASSWORD=<fill-locally>
INTDB_PROFILE__PUNKTB_PROD_ADMIN__PGSSLMODE=prefer
INTDB_PROFILE__PUNKTB_PROD_ADMIN__WRITE_CLASS=prod

# DEV readonly
INTDB_PROFILE__INTDATA_DEV_RO__PGHOST=vds.intdata.pro
INTDB_PROFILE__INTDATA_DEV_RO__PGPORT=5432
INTDB_PROFILE__INTDATA_DEV_RO__PGDATABASE=intdata
INTDB_PROFILE__INTDATA_DEV_RO__PGUSER=db_readonly_dev
INTDB_PROFILE__INTDATA_DEV_RO__PGPASSWORD=<fill-locally>
INTDB_PROFILE__INTDATA_DEV_RO__PGSSLMODE=prefer
INTDB_PROFILE__INTDATA_DEV_RO__WRITE_CLASS=nonprod

# DEV migrator
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGHOST=vds.intdata.pro
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGPORT=5432
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGDATABASE=intdata
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGUSER=db_migrator_dev
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGPASSWORD=<fill-locally>
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__PGSSLMODE=prefer
INTDB_PROFILE__INTDATA_DEV_MIGRATOR__WRITE_CLASS=nonprod

# DEV admin (breakglass only)
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGHOST=vds.intdata.pro
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGPORT=5432
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGDATABASE=intdata
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGUSER=db_admin_dev
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGPASSWORD=<fill-locally>
INTDB_PROFILE__INTDATA_DEV_ADMIN__PGSSLMODE=prefer
INTDB_PROFILE__INTDATA_DEV_ADMIN__WRITE_CLASS=nonprod

# Remote disposable test DB contour for /int/data is retired.
# For clean smoke/bootstrap use `intdb local-test run` on the owner PC instead.
