#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$(cd "$script_dir/../ops/lib" && pwd)/common.sh"

state="${1:-}"

if [[ "$state" != "prepared" ]]; then
  exit 0
fi

allow_new_branch="${PUNCTB_ALLOW_NEW_BRANCH:-NO}"
allow_branch_name="${PUNCTB_ALLOW_BRANCH_NAME:-}"

while read -r old_sha new_sha ref_name; do
  [[ -n "${ref_name:-}" ]] || continue
  [[ "$ref_name" == refs/heads/* ]] || continue
  [[ "$new_sha" == "0000000000000000000000000000000000000000" ]] && continue
  [[ "$old_sha" == "0000000000000000000000000000000000000000" ]] || continue

  branch_name="${ref_name#refs/heads/}"

  if [[ "$branch_name" == "dev" ]]; then
    origin_dev_sha="$(git rev-parse -q --verify refs/remotes/origin/dev 2>/dev/null || true)"
    if [[ -n "$origin_dev_sha" && "$new_sha" == "$origin_dev_sha" ]]; then
      continue
    fi
  fi

  if [[ "$allow_new_branch" == "YES" ]]; then
    if [[ -z "$allow_branch_name" || "$allow_branch_name" == "$branch_name" ]]; then
      continue
    fi
  fi

  echo "[BRANCH_CREATE_BLOCKED] creating local branch '$branch_name' is forbidden without owner approval" >&2
  echo "Use PUNCTB_ALLOW_NEW_BRANCH=YES PUNCTB_ALLOW_BRANCH_NAME=$branch_name for an explicitly approved creation." >&2
  exit 1
done

exit 0
