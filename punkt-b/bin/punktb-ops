#!/usr/bin/env bash
set -euo pipefail

ops_home="${PUNKTB_OPS_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
export PUNKTB_OPS_HOME="$ops_home"

if [[ $# -lt 1 ]]; then
  echo "Usage: punktb-ops <command> [args...]" >&2
  exit 2
fi

command="$1"
shift

case "$command" in
  policy:swarm)
    exec bash "$ops_home/ops/gates/swarm_policy_check.sh" "$@"
    ;;
  issue:hooks:install)
    exec bash "$ops_home/ops/issue/install_issue_hooks.sh" "$@"
    ;;
  issue:commit)
    exec bash "$ops_home/ops/issue/issue_commit.sh" "$@"
    ;;
  issue:push:done)
    exec bash "$ops_home/ops/issue/issue_push_done.sh" "$@"
    ;;
  issue:done)
    exec bash "$ops_home/ops/issue/issue_done.sh" "$@"
    ;;
  issue:audit:local)
    exec bash "$ops_home/ops/issue/issue_audit_local.sh" "$@"
    ;;
  migration:apply:guarded)
    exec bash "$ops_home/ops/db/migration_apply_gate.sh" "$@"
    ;;
  teamlead:orchestrate)
    exec bash "$ops_home/ops/teamlead/teamlead_orchestrator.sh" "$@"
    ;;
  release:prepare)
    exec bash "$ops_home/ops/release/release_prepare.sh" "$@"
    ;;
  release:main)
    exec bash "$ops_home/ops/release/release_main.sh" "$@"
    ;;
  *)
    echo "[UNKNOWN_COMMAND] $command" >&2
    exit 2
    ;;
esac
