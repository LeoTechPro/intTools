#!/usr/bin/env bash
set -euo pipefail

message_file="${1:-}"
if [[ -z "$message_file" ]]; then
  echo "[ARGUMENT] commit-msg hook requires message file path" >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"
current_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"
if [[ "$current_branch" != "dev" && "$current_branch" != "main" ]]; then
  exit 0
fi

mapfile -t staged_files < <(git -C "$repo_root" diff --cached --name-only)
for path in "${staged_files[@]}"; do
  case "$path" in
    docs/release.md)
      echo "[FORBIDDEN_FAST_COMMIT_TARGET] docs/release.md must go through release:prepare / issue:commit --full" >&2
      exit 1
      ;;
    backend/init/migrations/*|backend/init/migration_manifest.lock)
      echo "[FORBIDDEN_FAST_COMMIT_TARGET] migration scope must go through migration:apply:guarded or issue:commit --full" >&2
      exit 1
      ;;
  esac
done

python3 - "$message_file" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
visible = "\n".join(line for line in text.splitlines() if not line.lstrip().startswith("#"))
if re.search(r"(?i)\b(?:Fixes|Closes|Resolves)\s*#[0-9]+\b", visible):
    print(
        "[FORBIDDEN_CLOSE_KEYWORD] commit message must not contain Fixes/Closes/Resolves #<id>; use `Refs #<id>`",
        file=sys.stderr,
    )
    raise SystemExit(1)
PY
